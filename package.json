{
  "name": "chatter",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names 'vite, server' --kill-others 'vite --host 0.0.0.0 --open' 'cargo run --manifest-path ./server/Cargo.toml'",
    "open": "vite --open",
    "build": "run-p vite-build && cargo build --manifest-path ./server/Cargo.toml",
    "vite-build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "server": "run-p vite-build && cargo run --manifest-path ./server/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.1",
    "axios": "^1.6.2",
    "pinia": "^2.0.32",
    "pinia-plugin-persistedstate": "^3.2.0",
    "vue": "^3.3.4",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.6",
    "@types/node": "^18.14.2",
    "@vitejs/plugin-vue": "^4.2.3",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "daisyui": "^4.4.23",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.32",
    "postcss-import": "^15.1.0",
    "prettier": "^2.8.4",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.0.2",
    "vite": "^4.4.4",
    "vue-tsc": "^1.8.5"
  }
}
