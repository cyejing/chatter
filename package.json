{
  "name": "chatter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names 'vite, shuttle' --kill-others 'vite --host 0.0.0.0' 'cargo shuttle run --working-directory ./translater/'",
    "shuttle-login": "cargo shuttle login --working-directory ./translater/",
    "start": "cargo shuttle project start --working-directory ./translater/",
    "stop": "cargo shuttle project stop --working-directory ./translater/",
    "preview": "npm run build && cargo shuttle run --working-directory ./translater/",
    "deploy": "npm run build && cargo shuttle deploy --working-directory ./translater/ --allow-dirty",
    "build": "npm run check && vite build && cargo build --manifest-path ./translater/Cargo.toml",
    "check": "run-p vue-check cargo-check clippy format cargo-fmt",
    "build-only": "vite build",
    "vue-check": "vue-tsc --noEmit",
    "cargo-check": "cargo check --manifest-path ./translater/Cargo.toml",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "clippy": "cargo clippy --manifest-path ./translater/Cargo.toml -- -D warnings ",
    "format": "prettier --write src/",
    "cargo-fmt": "cargo fmt --check -v --manifest-path ./translater/Cargo.toml"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "pinia": "^2.0.32",
    "pinia-plugin-persistedstate": "^3.2.0",
    "vue": "^3.2.47",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@headlessui/vue": "^1.7.12",
    "@heroicons/vue": "^2.0.17",
    "@rushstack/eslint-patch": "^1.2.0",
    "@types/node": "^18.14.2",
    "@types/postcss-import": "^14.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.2",
    "@vue/tsconfig": "^0.1.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.34.0",
    "eslint-plugin-vue": "^9.9.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-import": "^15.1.0",
    "prettier": "^2.8.4",
    "tailwindcss": "^3.3.1",
    "typescript": "^4.9.3",
    "vite": "^4.2.0",
    "concurrently": "^8.2.0",
    "vue-tsc": "^1.2.0"
  }
}
